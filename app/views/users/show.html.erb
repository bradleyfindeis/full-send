<div class="min-h-screen bg-neutral-950">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <%= link_to leaderboard_index_path, class: "inline-flex items-center text-neutral-400 hover:text-white transition-colors mb-4" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to Leaderboard
      <% end %>

      <div class="flex items-center gap-4">
        <div class="w-16 h-16 bg-neutral-700 rounded-full flex items-center justify-center">
          <span class="text-white text-2xl font-bold"><%= @user.name.first.upcase %></span>
        </div>
        <div>
          <h1 class="text-2xl font-bold text-white">
            <%= @user.name %>
            <% if @user == current_user %>
              <span class="text-theme-light text-sm ml-2">(You)</span>
            <% end %>
          </h1>
          <p class="text-neutral-400">Rank #<%= @user_rank %> &bull; <%= @user.total_points %> points</p>
        </div>
      </div>
    </div>

    <% if @season_predictions.any? %>
      <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 mb-6">
        <h2 class="text-lg font-semibold text-white mb-4">Season Predictions</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <% @season_predictions.each do |prediction| %>
            <% if prediction.drivers_champion.present? %>
              <div class="flex items-center justify-between p-3 bg-neutral-800/50 rounded-lg">
                <div class="flex items-center gap-3">
                  <span class="px-2 py-1 bg-theme-20 text-theme-light text-xs font-medium rounded">
                    Drivers Champion
                  </span>
                  <span class="text-white"><%= prediction.drivers_champion.name %></span>
                </div>
              </div>
            <% end %>
            <% if prediction.constructors_champion.present? %>
              <div class="flex items-center justify-between p-3 bg-neutral-800/50 rounded-lg">
                <div class="flex items-center gap-3">
                  <span class="px-2 py-1 bg-theme-20 text-theme-light text-xs font-medium rounded">
                    Constructors Champion
                  </span>
                  <span class="text-white"><%= prediction.constructors_champion.name %></span>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6">
      <h2 class="text-lg font-semibold text-white mb-4">Race Predictions</h2>

      <% if @predictions_by_race.any? %>
        <div class="space-y-6">
          <% @predictions_by_race.each do |race, predictions| %>
            <div class="border-b border-neutral-800 pb-6 last:border-0 last:pb-0">
              <div class="flex items-center justify-between mb-4">
                <%= link_to race_path(race), class: "group" do %>
                  <h3 class="text-white font-medium group-hover:text-theme-light transition-colors">
                    Round <%= race.round %>: <%= race.name %>
                  </h3>
                <% end %>
                <% race_points = predictions.sum(&:points_earned) %>
                <span class="text-<%= race_points > 0 ? 'green' : 'neutral' %>-400 font-mono font-semibold">
                  <%= race_points > 0 ? "+#{race_points}" : race_points %>
                </span>
              </div>

              <div class="space-y-3">
                <% %w[qualifying sprint race].each do |session| %>
                  <% session_preds = predictions.select { |p| p.session_type == session && p.prediction_type != "podium_sweep" } %>
                  <% next if session_preds.empty? %>

                  <div>
                    <p class="text-neutral-500 text-xs uppercase tracking-wider mb-2"><%= session %></p>
                    <div class="flex flex-wrap gap-2">
                      <% session_preds.sort_by { |p| p.position || 999 }.each do |prediction| %>
                        <% correct = prediction.points_earned > 0 %>
                        <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg <%= correct ? 'bg-green-900/30 border border-green-700/50' : 'bg-neutral-800/50 border border-neutral-700/50' %>">
                          <% if prediction.prediction_type == "position" %>
                            <span class="text-xs font-mono <%= correct ? 'text-green-400' : 'text-neutral-500' %>">P<%= prediction.position %></span>
                          <% else %>
                            <span class="text-xs font-mono <%= correct ? 'text-green-400' : 'text-neutral-500' %>">FL</span>
                          <% end %>
                          <span class="text-sm <%= correct ? 'text-green-300' : 'text-neutral-400' %>"><%= prediction.driver.name %></span>
                          <% if correct %>
                            <span class="text-green-400 text-xs font-mono">+<%= prediction.points_earned %></span>
                          <% end %>
                        </div>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-neutral-500 text-center py-8">No predictions yet</p>
      <% end %>
    </div>
  </div>
</div>
