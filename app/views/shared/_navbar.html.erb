<nav class="fixed top-0 left-0 right-0 z-50 bg-neutral-900/95 backdrop-blur border-b border-neutral-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <div class="flex items-center space-x-8">
        <%= link_to root_path, class: "flex items-center space-x-2" do %>
          <div class="w-8 h-8 bg-theme rounded flex items-center justify-center overflow-hidden">
            <span class="font-black text-sm italic transform -skew-x-12" style="color: var(--theme-text)">FS</span>
          </div>
          <span class="text-white font-semibold tracking-tight hidden sm:block">FULL SEND</span>
        <% end %>

        <div class="hidden md:flex items-center space-x-1">
          <%= link_to "Dashboard", root_path, class: "px-3 py-2 rounded-lg text-sm font-medium #{current_page?(root_path) ? 'bg-neutral-800 text-white' : 'text-neutral-400 hover:text-white hover:bg-neutral-800/50'} transition-colors" %>
          <%= link_to "Races", races_path, class: "px-3 py-2 rounded-lg text-sm font-medium #{request.path.start_with?('/races') ? 'bg-neutral-800 text-white' : 'text-neutral-400 hover:text-white hover:bg-neutral-800/50'} transition-colors" %>
          <%= link_to "Results", results_path, class: "px-3 py-2 rounded-lg text-sm font-medium #{request.path.start_with?('/results') ? 'bg-neutral-800 text-white' : 'text-neutral-400 hover:text-white hover:bg-neutral-800/50'} transition-colors" %>
          <%= link_to "Leaderboard", leaderboard_index_path, class: "px-3 py-2 rounded-lg text-sm font-medium #{current_page?(leaderboard_index_path) ? 'bg-neutral-800 text-white' : 'text-neutral-400 hover:text-white hover:bg-neutral-800/50'} transition-colors" %>
          <% if current_user&.admin? %>
            <%= link_to "Admin", admin_root_path, class: "px-3 py-2 rounded-lg text-sm font-medium #{request.path.start_with?('/admin') ? 'bg-neutral-800 text-white' : 'text-neutral-400 hover:text-white hover:bg-neutral-800/50'} transition-colors" %>
          <% end %>
        </div>
      </div>

      <div class="flex items-center space-x-4">
        <div class="hidden sm:flex items-center space-x-2 bg-neutral-800/50 rounded-lg px-3 py-1.5">
          <span class="text-neutral-400 text-sm">Points:</span>
          <span class="text-white font-mono font-semibold"><%= current_user&.total_points || 0 %></span>
        </div>

        <div class="relative" data-controller="dropdown">
          <button data-action="click->dropdown#toggle" class="flex items-center space-x-2 text-neutral-300 hover:text-white transition-colors">
            <div class="w-8 h-8 bg-neutral-700 rounded-full flex items-center justify-center">
              <span class="text-sm font-medium"><%= current_user&.name&.first&.upcase %></span>
            </div>
            <svg class="w-4 h-4 hidden sm:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>

          <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-48 bg-neutral-800 border border-neutral-700 rounded-lg shadow-xl py-1">
            <div class="px-4 py-2 border-b border-neutral-700">
              <p class="text-sm font-medium text-white"><%= current_user&.name %></p>
              <p class="text-xs text-neutral-400 truncate"><%= current_user&.email_address %></p>
            </div>
            <%= link_to "Season Picks", season_prediction_path, class: "block px-4 py-2 text-sm text-neutral-300 hover:bg-neutral-700 hover:text-white" %>
            <%= link_to "Settings", edit_settings_path, class: "block px-4 py-2 text-sm text-neutral-300 hover:bg-neutral-700 hover:text-white" %>
            <% if current_user&.admin? %>
              <%= link_to "Admin Panel", admin_root_path, class: "block px-4 py-2 text-sm text-neutral-300 hover:bg-neutral-700 hover:text-white" %>
            <% end %>
            <%= button_to "Sign out", session_path, method: :delete, class: "w-full text-left px-4 py-2 text-sm text-neutral-300 hover:bg-neutral-700 hover:text-white" %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="md:hidden border-t border-neutral-800">
    <div class="flex justify-around py-2">
      <%= link_to root_path, class: "flex flex-col items-center py-2 px-2 #{current_page?(root_path) ? 'text-theme' : 'text-neutral-400'}" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
        <span class="text-xs mt-1">Home</span>
      <% end %>
      <%= link_to races_path, class: "flex flex-col items-center py-2 px-2 #{request.path.start_with?('/races') ? 'text-theme' : 'text-neutral-400'}" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
        <span class="text-xs mt-1">Races</span>
      <% end %>
      <%= link_to results_path, class: "flex flex-col items-center py-2 px-2 #{request.path.start_with?('/results') ? 'text-theme' : 'text-neutral-400'}" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span class="text-xs mt-1">Results</span>
      <% end %>
      <%= link_to leaderboard_index_path, class: "flex flex-col items-center py-2 px-2 #{current_page?(leaderboard_index_path) ? 'text-theme' : 'text-neutral-400'}" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
        </svg>
        <span class="text-xs mt-1">Standings</span>
      <% end %>
    </div>
  </div>
</nav>
