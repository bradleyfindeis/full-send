<div class="min-h-screen bg-neutral-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-white">F1 Results & Standings</h1>
      <p class="text-neutral-400 mt-1"><%= @season&.year || Time.current.year %> Season</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Driver Standings -->
      <div class="bg-neutral-900 border border-neutral-800 rounded-xl overflow-hidden">
        <div class="px-6 py-4 border-b border-neutral-800">
          <h2 class="text-lg font-semibold text-white">Driver Championship</h2>
        </div>
        
        <% if @driver_standings.any? %>
          <div class="divide-y divide-neutral-800">
            <% @driver_standings.first(10).each_with_index do |standing, index| %>
              <% driver_name = "#{standing.dig('Driver', 'givenName')} #{standing.dig('Driver', 'familyName')}" %>
              <% team_name = standing.dig('Constructors', 0, 'name') %>
              <% team_id = standing.dig('Constructors', 0, 'constructorId') %>
              <div class="flex items-center gap-4 px-6 py-3 hover:bg-neutral-800/50 transition-colors">
                <div class="w-8 text-center">
                  <span class="<%= index < 3 ? 'text-white font-bold' : 'text-neutral-400' %> text-lg">
                    <%= standing['position'] %>
                  </span>
                </div>
                <div class="w-1 h-8 rounded-full" style="background-color: <%= team_color(team_id) %>"></div>
                <div class="flex-1 min-w-0">
                  <p class="text-white font-medium truncate"><%= driver_name %></p>
                  <p class="text-neutral-500 text-xs truncate"><%= clean_team_name(team_name) %></p>
                </div>
                <div class="text-right">
                  <span class="text-white font-mono font-semibold"><%= standing['points'] %></span>
                  <span class="text-neutral-500 text-xs ml-1">pts</span>
                </div>
              </div>
            <% end %>
          </div>
          
          <% if @driver_standings.length > 10 %>
            <div class="px-6 py-3 border-t border-neutral-800">
              <button onclick="document.getElementById('full-driver-standings').classList.toggle('hidden')" class="text-red-500 hover:text-red-400 text-sm">
                Show all drivers
              </button>
            </div>
            <div id="full-driver-standings" class="hidden divide-y divide-neutral-800 border-t border-neutral-800">
              <% @driver_standings.drop(10).each do |standing| %>
                <% driver_name = "#{standing.dig('Driver', 'givenName')} #{standing.dig('Driver', 'familyName')}" %>
                <% team_id = standing.dig('Constructors', 0, 'constructorId') %>
                <div class="flex items-center gap-4 px-6 py-3 hover:bg-neutral-800/50 transition-colors">
                  <div class="w-8 text-center">
                    <span class="text-neutral-400 text-lg"><%= standing['position'] %></span>
                  </div>
                  <div class="w-1 h-8 rounded-full" style="background-color: <%= team_color(team_id) %>"></div>
                  <div class="flex-1 min-w-0">
                    <p class="text-white font-medium truncate"><%= driver_name %></p>
                  </div>
                  <div class="text-right">
                    <span class="text-white font-mono font-semibold"><%= standing['points'] %></span>
                    <span class="text-neutral-500 text-xs ml-1">pts</span>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <div class="px-6 py-12 text-center">
            <p class="text-neutral-400">No standings data available yet.</p>
            <p class="text-neutral-500 text-sm mt-1">Standings will appear once the season begins.</p>
          </div>
        <% end %>
      </div>

      <!-- Constructor Standings -->
      <div class="bg-neutral-900 border border-neutral-800 rounded-xl overflow-hidden">
        <div class="px-6 py-4 border-b border-neutral-800">
          <h2 class="text-lg font-semibold text-white">Constructor Championship</h2>
        </div>
        
        <% if @constructor_standings.any? %>
          <div class="divide-y divide-neutral-800">
            <% @constructor_standings.each_with_index do |standing, index| %>
              <% team_name = standing.dig('Constructor', 'name') %>
              <% team_id = standing.dig('Constructor', 'constructorId') %>
              <div class="flex items-center gap-4 px-6 py-3 hover:bg-neutral-800/50 transition-colors">
                <div class="w-8 text-center">
                  <span class="<%= index < 3 ? 'text-white font-bold' : 'text-neutral-400' %> text-lg">
                    <%= standing['position'] %>
                  </span>
                </div>
                <div class="w-1 h-8 rounded-full" style="background-color: <%= team_color(team_id) %>"></div>
                <div class="flex-1 min-w-0">
                  <p class="text-white font-medium truncate"><%= clean_team_name(team_name) %></p>
                  <p class="text-neutral-500 text-xs"><%= standing['wins'] %> wins</p>
                </div>
                <div class="text-right">
                  <span class="text-white font-mono font-semibold"><%= standing['points'] %></span>
                  <span class="text-neutral-500 text-xs ml-1">pts</span>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="px-6 py-12 text-center">
            <p class="text-neutral-400">No standings data available yet.</p>
            <p class="text-neutral-500 text-sm mt-1">Standings will appear once the season begins.</p>
          </div>
        <% end %>
      </div>

      <!-- Recent Race Results -->
      <div class="bg-neutral-900 border border-neutral-800 rounded-xl overflow-hidden">
        <div class="px-6 py-4 border-b border-neutral-800">
          <h2 class="text-lg font-semibold text-white">Race Results</h2>
        </div>
        
        <% if @completed_races.any? %>
          <div class="divide-y divide-neutral-800">
            <% @completed_races.each do |race| %>
              <%= link_to result_path(race), class: "block px-6 py-4 hover:bg-neutral-800/50 transition-colors" do %>
                <div class="flex items-center justify-between mb-2">
                  <span class="text-white font-medium"><%= race.name %></span>
                  <span class="text-neutral-500 text-sm">Round <%= race.round %></span>
                </div>
                <div class="flex items-center gap-4">
                  <% race.race_results.for_session("race").podium.ordered.each do |result| %>
                    <div class="flex items-center gap-2">
                      <span class="text-neutral-400 text-xs">P<%= result.position %></span>
                      <span class="text-white text-sm"><%= result.driver.code || result.driver.short_name %></span>
                    </div>
                  <% end %>
                </div>
                <p class="text-neutral-500 text-xs mt-2"><%= race.race_date&.strftime("%b %d, %Y") %></p>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="px-6 py-12 text-center">
            <p class="text-neutral-400">No race results yet.</p>
            <p class="text-neutral-500 text-sm mt-1">Results will appear after races are completed.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
