<div class="min-h-screen bg-neutral-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-white"><%= @season&.year %> Race Calendar</h1>
      <p class="text-neutral-400 mt-1"><%= @races.count %> races</p>
    </div>

    <div class="space-y-4">
      <% @races.each do |race| %>
        <% status = race.status %>
        <% user_predictions_count = @user_predictions_by_race[race.id] || 0 %>
        <% max_predictions = race.has_sprint? ? 10 : 7 %>
        <% can_predict = !race.race_locked? %>
        
        <%= link_to (can_predict ? new_race_prediction_path(race) : race_path(race)), class: "block bg-neutral-900 border border-neutral-800 rounded-xl p-4 sm:p-6 hover:border-neutral-700 hover:bg-neutral-900/80 transition-colors cursor-pointer" do %>
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 flex items-center justify-center rounded-lg <%= status == :completed ? 'bg-green-600/20 text-green-400' : status == :in_progress ? 'bg-yellow-600/20 text-yellow-400' : 'bg-neutral-800 text-neutral-400' %>">
                <span class="text-lg font-bold"><%= race.round %></span>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-white"><%= race.name %></h3>
                <p class="text-neutral-400 text-sm">
                  <%= race.circuit_name %>, <%= race.circuit_country %>
                </p>
                <div class="flex flex-wrap items-center gap-2 sm:gap-4 mt-2 text-sm">
                  <span class="text-neutral-500">
                    <svg class="inline w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <%= local_time(race.race_date, format: :date_only) || "TBD" %>
                  </span>
                  <% if race.has_sprint? %>
                    <span class="px-2 py-0.5 bg-purple-600/20 text-purple-400 text-xs rounded-full">Sprint Weekend</span>
                  <% end %>
                </div>
              </div>
            </div>

            <div class="flex items-center gap-3">
              <% if user_predictions_count > 0 %>
                <% if user_predictions_count >= max_predictions %>
                  <span class="flex items-center gap-1 px-2 py-1 bg-green-600/20 text-green-400 text-sm rounded-lg">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    Complete
                  </span>
                <% else %>
                  <span class="flex items-center gap-1 px-2 py-1 bg-yellow-600/20 text-yellow-400 text-sm rounded-lg">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
                    </svg>
                    <%= user_predictions_count %>/<%= max_predictions %>
                  </span>
                <% end %>
              <% elsif race.race_locked? %>
                <span class="flex items-center gap-1 px-2 py-1 bg-red-600/20 text-red-400 text-sm rounded-lg">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                  </svg>
                  Missed
                </span>
              <% end %>

              <% if can_predict %>
                <span class="px-4 py-2 bg-theme text-sm font-medium rounded-lg" style="color: var(--theme-text)">
                  Predict
                </span>
              <% elsif status == :completed %>
                <span class="px-4 py-2 bg-neutral-700 text-white text-sm font-medium rounded-lg">
                  Results
                </span>
              <% else %>
                <span class="px-4 py-2 bg-neutral-700 text-white text-sm font-medium rounded-lg">
                  View
                </span>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>

      <% if @races.empty? %>
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-12 text-center">
          <p class="text-neutral-400">No races scheduled yet. Data will sync automatically.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
