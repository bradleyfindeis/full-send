<div class="min-h-screen bg-neutral-950">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <%= link_to admin_root_path, class: "inline-flex items-center text-neutral-400 hover:text-white transition-colors mb-4" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to Admin
      <% end %>

      <h1 class="text-2xl font-bold text-white">Users</h1>
      <p class="text-neutral-400 mt-1"><%= @users.count %> registered users</p>
    </div>

    <% if flash[:notice] %>
      <div class="bg-green-900/50 border border-green-500 rounded-lg p-4 mb-6">
        <p class="text-green-200"><%= flash[:notice] %></p>
      </div>
    <% end %>

    <div class="bg-neutral-900 border border-neutral-800 rounded-xl overflow-hidden">
      <div class="hidden sm:grid grid-cols-12 gap-4 px-6 py-4 border-b border-neutral-800 text-neutral-400 text-sm font-medium">
        <div class="col-span-1">Rank</div>
        <div class="col-span-4">User</div>
        <div class="col-span-3">Email</div>
        <div class="col-span-2">Points</div>
        <div class="col-span-2">Actions</div>
      </div>

      <div class="divide-y divide-neutral-800">
        <% @users.each_with_index do |user, index| %>
          <div class="grid grid-cols-12 gap-4 px-6 py-4 items-center hover:bg-neutral-800/50 transition-colors">
            <div class="col-span-2 sm:col-span-1">
              <span class="text-neutral-400 font-mono"><%= index + 1 %></span>
            </div>
            <div class="col-span-10 sm:col-span-4 flex items-center gap-3">
              <div class="w-8 h-8 bg-neutral-700 rounded-full flex items-center justify-center flex-shrink-0">
                <span class="text-white text-sm font-medium"><%= user.name.first.upcase %></span>
              </div>
              <div class="min-w-0">
                <p class="text-white font-medium truncate">
                  <%= user.name %>
                  <% if user.admin? %>
                    <span class="text-red-400 text-xs ml-1">Admin</span>
                  <% end %>
                </p>
              </div>
            </div>
            <div class="col-span-6 sm:col-span-3">
              <span class="text-neutral-400 text-sm truncate"><%= user.email_address %></span>
            </div>
            <div class="col-span-3 sm:col-span-2">
              <span class="text-white font-mono font-medium"><%= user.total_points %></span>
            </div>
            <div class="col-span-3 sm:col-span-2">
              <%= link_to "Edit", edit_admin_user_path(user), class: "text-red-500 hover:text-red-400 text-sm" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
