<div class="min-h-screen bg-neutral-950">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <%= link_to admin_users_path, class: "inline-flex items-center text-neutral-400 hover:text-white transition-colors mb-4" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to Users
      <% end %>

      <h1 class="text-2xl font-bold text-white">Edit User</h1>
      <p class="text-neutral-400 mt-1"><%= @user.email_address %></p>
    </div>

    <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6">
      <%= form_with model: @user, url: admin_user_path(@user), method: :patch, class: "space-y-6" do |form| %>
        <% if flash[:alert] %>
          <div class="bg-red-900/50 border border-red-500 rounded-lg p-4">
            <p class="text-red-200 text-sm"><%= flash[:alert] %></p>
          </div>
        <% end %>
        <% if @user.errors.any? %>
          <div class="bg-red-900/50 border border-red-500 rounded-lg p-4">
            <ul class="text-red-200 text-sm space-y-1">
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <label class="block text-sm font-medium text-neutral-300 mb-2">Name</label>
          <%= form.text_field :name, class: "w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-red-600" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-neutral-300 mb-2">Email</label>
          <%= form.email_field :email_address, class: "w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-red-600" %>
        </div>

        <div class="flex items-center gap-3">
          <%= form.check_box :admin, class: "w-5 h-5 rounded bg-neutral-800 border-neutral-700 text-red-600 focus:ring-red-600" %>
          <label class="text-neutral-300">Administrator</label>
        </div>

        <div class="flex justify-between items-center">
          <% unless @user == current_user %>
            <%= button_to "Delete User", admin_user_path(@user), method: :delete,
                data: { turbo_confirm: "Delete #{@user.name}? This will remove all their predictions and cannot be undone." },
                class: "px-4 py-2 text-red-400 hover:text-red-300 hover:bg-red-900/30 rounded-lg transition-colors text-sm",
                form: { class: "inline" } %>
          <% else %>
            <div></div>
          <% end %>
          <div class="flex gap-4">
            <%= link_to "Cancel", admin_users_path, class: "px-6 py-3 bg-neutral-700 hover:bg-neutral-600 text-white font-medium rounded-lg transition-colors" %>
            <%= form.submit "Save Changes", class: "px-6 py-3 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg transition-colors cursor-pointer" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
