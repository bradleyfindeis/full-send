<div class="min-h-screen bg-neutral-950">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <%= link_to root_path, class: "inline-flex items-center text-neutral-400 hover:text-white transition-colors mb-4" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to Dashboard
      <% end %>

      <h1 class="text-2xl font-bold text-white">Season Champion Predictions</h1>
      <p class="text-neutral-400 mt-1"><%= @season&.year %> Season</p>
    </div>

    <% if @prediction.locked? %>
      <div class="bg-neutral-900/50 border border-neutral-700 rounded-xl p-4 mb-8">
        <div class="flex items-center gap-3 text-neutral-400">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
          <span>Locked on <%= @prediction.locked_at.strftime("%B %d, %Y at %H:%M") %></span>
        </div>
      </div>
    <% end %>

    <div class="space-y-6">
      <div class="bg-gradient-to-br from-neutral-900 to-neutral-800 border border-neutral-700 rounded-xl p-6">
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-yellow-500/20 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <div>
              <h2 class="text-lg font-semibold text-white">Drivers Champion</h2>
              <p class="text-neutral-400 text-sm">50 points if correct</p>
            </div>
          </div>
          <% if @prediction.points_earned > 0 && @prediction.drivers_champion %>
            <span class="text-green-400 font-mono font-bold text-xl">+50</span>
          <% end %>
        </div>

        <% if @prediction.drivers_champion %>
          <div class="flex items-center gap-4 p-4 bg-neutral-800/50 rounded-lg">
            <div class="w-14 h-14 rounded-full flex items-center justify-center text-white font-bold text-lg" style="<%= @prediction.drivers_champion.team&.badge_style %>">
              <%= @prediction.drivers_champion.number || @prediction.drivers_champion.code || "?" %>
            </div>
            <div>
              <p class="text-white font-semibold text-lg"><%= @prediction.drivers_champion.name %></p>
              <p class="text-neutral-400 text-sm"><%= @prediction.drivers_champion.team&.name %></p>
            </div>
          </div>
        <% else %>
          <p class="text-neutral-500 italic">Not selected</p>
        <% end %>
      </div>

      <div class="bg-gradient-to-br from-neutral-900 to-neutral-800 border border-neutral-700 rounded-xl p-6">
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-blue-500/20 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
            </div>
            <div>
              <h2 class="text-lg font-semibold text-white">Constructors Champion</h2>
              <p class="text-neutral-400 text-sm">50 points if correct</p>
            </div>
          </div>
          <% if @prediction.points_earned >= 50 && @prediction.constructors_champion %>
            <span class="text-green-400 font-mono font-bold text-xl">+50</span>
          <% end %>
        </div>

        <% if @prediction.constructors_champion %>
          <div class="flex items-center gap-4 p-4 bg-neutral-800/50 rounded-lg">
            <div class="w-14 h-14 rounded-lg flex items-center justify-center" style="<%= @prediction.constructors_champion.badge_style %>">
              <span class="text-white font-bold text-sm"><%= @prediction.constructors_champion.name[0..2].upcase %></span>
            </div>
            <div>
              <p class="text-white font-semibold text-lg"><%= @prediction.constructors_champion.name %></p>
            </div>
          </div>
        <% else %>
          <p class="text-neutral-500 italic">Not selected</p>
        <% end %>
      </div>

      <% unless @prediction.locked? %>
        <div class="flex justify-end">
          <%= link_to "Edit Predictions", new_season_prediction_path, class: "px-6 py-3 bg-neutral-700 hover:bg-neutral-600 text-white font-medium rounded-lg transition-colors" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
