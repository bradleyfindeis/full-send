<div class="min-h-screen flex items-center justify-center bg-neutral-950 px-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-white tracking-tight flex items-center justify-center gap-3">
        <div class="w-10 h-10 bg-red-600 rounded flex items-center justify-center">
          <span class="text-white font-black text-lg italic transform -skew-x-12">FS</span>
        </div>
        FULL SEND
      </h1>
      <p class="text-neutral-400 mt-2">Create your account</p>
    </div>

    <div class="bg-neutral-900 border border-neutral-800 rounded-lg p-8">
      <% if flash[:alert] %>
        <div class="bg-red-900/50 border border-red-500 rounded-lg p-4 mb-6">
          <p class="text-red-200 text-sm"><%= flash[:alert] %></p>
        </div>
      <% end %>

      <%= form_with model: @user, url: registration_path, class: "space-y-6" do |form| %>
        <% if @user.errors.any? %>
          <div class="bg-red-900/50 border border-red-500 rounded-lg p-4">
            <ul class="text-red-200 text-sm space-y-1">
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <label for="access_code" class="block text-sm font-medium text-neutral-300 mb-2">Access Code</label>
          <input type="text" name="access_code" id="access_code" value="<%= params[:access_code] %>"
                 class="w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-lg text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-red-600 focus:border-transparent uppercase tracking-widest"
                 placeholder="XXXXXXXX" required>
        </div>

        <div>
          <label for="user_name" class="block text-sm font-medium text-neutral-300 mb-2">Name</label>
          <%= form.text_field :name, class: "w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-lg text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-red-600 focus:border-transparent", placeholder: "Max Verstappen", required: true %>
        </div>

        <div>
          <label for="user_email_address" class="block text-sm font-medium text-neutral-300 mb-2">Email</label>
          <%= form.email_field :email_address, class: "w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-lg text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-red-600 focus:border-transparent", placeholder: "you@example.com", required: true %>
        </div>

        <div>
          <label for="user_password" class="block text-sm font-medium text-neutral-300 mb-2">Password</label>
          <%= form.password_field :password, class: "w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-lg text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-red-600 focus:border-transparent", placeholder: "••••••••", required: true %>
        </div>

        <div>
          <label for="user_password_confirmation" class="block text-sm font-medium text-neutral-300 mb-2">Confirm Password</label>
          <%= form.password_field :password_confirmation, class: "w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-lg text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-red-600 focus:border-transparent", placeholder: "••••••••", required: true %>
        </div>

        <div>
          <%= form.submit "Create Account", class: "w-full py-3 px-4 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg transition-colors cursor-pointer" %>
        </div>
      <% end %>

      <p class="text-center text-neutral-400 text-sm mt-6">
        Already have an account?
        <%= link_to "Sign in", new_session_path, class: "text-red-500 hover:text-red-400" %>
      </p>
    </div>
  </div>
</div>
